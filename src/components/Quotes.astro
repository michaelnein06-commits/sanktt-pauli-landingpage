---
const quotes = [
  { text: 'the playlist is the party before the party', size: 'text-3xl md:text-5xl lg:text-6xl' },
  { text: 'sunset sets the tone, music sets the mood', size: 'text-2xl md:text-4xl lg:text-5xl' },
  { text: 'curated, not calculated', size: 'text-3xl md:text-5xl lg:text-7xl' },
];
---

<section class="relative py-32 overflow-hidden">
  <!-- Background Gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-accent-primary/5 to-transparent pointer-events-none" />
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-accent-secondary/8 blur-[150px] pointer-events-none" />

  <div class="relative container mx-auto px-4">
    <div class="max-w-5xl mx-auto space-y-20">
      {quotes.map((quote, i) => (
        <div
          class={`animate-item text-center ${i === 1 ? 'md:text-right' : i === 2 ? 'md:text-left' : ''}`}
          style={`--delay: ${i * 150}ms`}
        >
          <blockquote class={`font-headline font-bold ${quote.size} leading-tight tracking-tight`}>
            <span class="bg-gradient-to-r from-text-primary to-text-secondary bg-clip-text text-transparent">
              {quote.text}
            </span>
          </blockquote>
        </div>
      ))}
    </div>
  </div>
</section>
