---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy Policy — sanktt.pauli">
  <div class="container mx-auto px-4 py-24 max-w-3xl">
    <a href="/" class="inline-flex items-center gap-2 text-text-secondary hover:text-accent-primary transition-colors duration-200 text-sm mb-12">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to sanktt.pauli
    </a>

    <h1 class="font-headline text-4xl md:text-5xl font-bold text-text-primary mb-12">
      Privacy Policy
    </h1>

    <div class="space-y-8 text-text-secondary leading-relaxed">
      <section>
        <h2 class="font-headline text-xl font-semibold text-text-primary mb-3">Overview</h2>
        <p>
          Your privacy matters. This website is designed to collect as little data as possible.
          No cookies, no tracking pixels, no personal data collection.
        </p>
      </section>

      <section>
        <h2 class="font-headline text-xl font-semibold text-text-primary mb-3">Analytics</h2>
        <p>
          We use <strong class="text-text-primary">Plausible Analytics</strong>, a privacy-friendly
          analytics tool that does not use cookies and does not collect any personal data.
          All data is aggregated and no individual visitors can be identified.
          Plausible is fully GDPR compliant without requiring a cookie banner.
        </p>
      </section>

      <section>
        <h2 class="font-headline text-xl font-semibold text-text-primary mb-3">Cookies</h2>
        <p>
          This website does not use cookies.
        </p>
      </section>

      <section>
        <h2 class="font-headline text-xl font-semibold text-text-primary mb-3">External Services</h2>
        <p>
          This website embeds Spotify playlists via official Spotify Embeds.
          When you interact with a Spotify embed, Spotify may collect data according to their own privacy policy.
          Please refer to
          <a href="https://www.spotify.com/privacy" target="_blank" rel="noopener noreferrer" class="text-accent-primary hover:underline">
            Spotify's Privacy Policy
          </a>
          for details.
        </p>
      </section>

      <section>
        <h2 class="font-headline text-xl font-semibold text-text-primary mb-3">Hosting</h2>
        <p>
          This website is hosted on a Hostinger VPS located in Europe.
          Server logs may temporarily store IP addresses for security purposes,
          which are automatically deleted after 14 days.
        </p>
      </section>

      <section>
        <h2 class="font-headline text-xl font-semibold text-text-primary mb-3">Your Rights (GDPR)</h2>
        <p>
          Under the General Data Protection Regulation (GDPR), you have the right to access,
          rectify, or delete any personal data we may hold. Since we do not collect personal data,
          there is typically nothing to request. If you have any questions, please contact us
          via the information provided in the
          <a href="/impressum" class="text-accent-primary hover:underline">Impressum</a>.
        </p>
      </section>

      <p class="text-sm text-text-secondary/60 pt-4">
        Last updated: March 2026
      </p>
    </div>
  </div>
</Layout>
